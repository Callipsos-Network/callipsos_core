  "query": "\n            UPDATE conversations\n            SET messages_json = messages_json || $1::jsonb,\n                updated_at = NOW()\n            WHERE user_id = $2 AND active = TRUE\n            RETURNING\n                id,\n                user_id AS \"user_id: UserId\",\n                messages_json,\n                active,\n                created_at,\n                updated_at\n            ",
