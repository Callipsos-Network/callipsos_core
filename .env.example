# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/callipsos_dev

# ── Lit Protocol Signing (Chipotle REST API) ─────────────────
# All 3 must be set to enable signing. If any is missing, signing
# is disabled and the validate endpoint still works without signatures.
#
# Get these from the Chipotle Dashboard: https://dashboard.dev.litprotocol.com
# 1. Create account → get account API key
# 2. Create usage API key → LIT_API_KEY
# 3. Create PKP wallet → LIT_PKP_ADDRESS
# 4. Create group, add PKP to group
LIT_API_URL=https://api.dev.litprotocol.com
LIT_API_KEY=
LIT_PKP_ADDRESS=

## ── Anthropic API Key for agents ──────────────────────────────
ANTHROPIC_API_KEY=

## ── 32 byte hex key for encrypting user LLM API keys. Generate with: openssl rand -hex 32 ──────────────────────────────
# WARNING: Please note that changing this key invalidates all stored encrypted API keys.
ENCRYPTION_KEY=

## ── Callipsos Bot Telegram Token ──────────────────────────────
## Step 1: Go to @BotFather on telegram
## Step 2: Type the /newbot command
## Step 3: Choose a name for the bot (Eg `CallipsosDev`)
## Step 4: Choose a username for the bot (Note it has to end with bot eg `callipsos_agent_bot` )
## Step 5: Use the token given to access the Bot and add it here:
TELOXIDE_TOKEN=

## ── ERC8004 Agent Identity on Base Sepolia ──────────────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
## Add the test private key for signing the agent's identity registry here. 
## Network: Base Sepolia 
## Note!!!! Please use a test wallet do not use your main wallet with real funds!!!
AGENT_PRIVATE_KEY=
## You'll add the agent ID here after successful registration, you'll find the ID in the logs:
## Agent registered! agentId: 3196
ERC8004_AGENT_ID=
## Official Base Sepolia erc8004 identity and reputation registry contracts
ERC8004_IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e
ERC8004_REPUTATION_REGISTRY=0x8004B663056A597Dffe9eCcC1965A193B7388713
ERC8004_AGENT_URI=https://raw.githubusercontent.com/Callipsos-Network/callipsos_core/main/agent.json