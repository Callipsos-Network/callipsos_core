  "services": [
    {
      "name": "web",
      "endpoint": "https://github.com/Callipsos-Network/callipsos_core"
    },
    {
      "name": "telegram",
      "endpoint": "https://t.me/callipsos_agent_bot"
    }
  ],
  "x402Support": false,
  "active": true,
  "registrations": [
    {
        "agentId": 3196,
        "agentRegistry": "eip155:84532:0x8004A818BFB912233c491871b3d84c89A494BD9e",
        "chainId": 84532
    }
  ],
  "capabilities": [
    "policy-engine",
    "transaction-validation",
    "reasoning-audit",
    "lit-protocol-signing",
    "natural-language-policy-setting",
    "defi-yield-scouting"
  ],
  "trust": {
